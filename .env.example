# Telegram bot token from @BotFather (required)
BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to create/approve tasks and review submissions.
# Find your ID by messaging @userinfobot. Example: ADMIN_IDS=12345678,87654321
ADMIN_IDS=

# PostgreSQL connection string (required). Railway injects this from its Postgres
# plugin. For local dev, `docker compose up -d` starts one:
DATABASE_URL=postgresql://multiagency:multiagency@localhost:5455/multiagency

# Optional chat where newly opened tasks are announced — the primary public-discovery
# surface. Any chat works: a private/public group or a broadcast channel (numeric id like
# -1001234567890, or @publicname). The bot must be a member (an admin with "Post Messages"
# for a channel). Only points at /open; leave empty to disable (approval is unaffected).
ANNOUNCE_CHAT_ID=

# Bot @username without the @ (optional). When set, the announcement post carries a
# deep-link "Apply" button (t.me/<username>?start=t<taskId>) instead of only a /open hint.
BOT_USERNAME=

# Global cap on outbound notifications per second, applied across the whole queue by the
# single delivery worker (optional, default 25; Telegram's bulk limit is ~30/s).
NOTIFY_RATE_PER_SEC=25

# Max pending (undecided) applications one contributor may hold at once (optional, default 5).
MAX_OPEN_APPLICATIONS=5

# NEAR AI Cloud API key for AI assistance (optional — AI features degrade gracefully if unset).
# Generate one at https://cloud.near.ai
NEAR_AI_API_KEY=

# NEAR AI Cloud base URL (optional, OpenAI-compatible endpoint)
NEAR_AI_BASE_URL=https://cloud-api.near.ai/v1

# Model used for AI assistance (optional). See https://cloud-api.near.ai/v1/models for options.
# Prefer NEAR-native private-TEE chat models. Avoid reasoning models (gpt-oss, qwen3.x) —
# they may return empty content for short completions. Alternative: google/gemma-4-31B-it
AI_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Signal detection (per-group opt-in via /enablesignals; needs NEAR_AI_API_KEY).
# Minimum AI score (0-10) a group message must reach to become a Draft task (default 6).
SIGNAL_SCORE_THRESHOLD=6

# Max AI evaluations per room per hour — bounds the AI bill of a flooded group (default 20).
SIGNAL_MAX_PER_HOUR=20
